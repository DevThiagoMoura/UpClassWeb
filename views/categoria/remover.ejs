<% const categoria = locals.categoria || {} %>
<% const mensagemBloqueio = locals.mensagemBloqueio || '' %>
<% const totalCursos = Array.isArray(categoria.cursos) ? categoria.cursos.length : 0 %>

<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= locals.titulo %></h4>
            <p class="mb-0">&raquo; <%= locals.subtitulo %></p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/categorias">Consulta de Categorias</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Excluir Categoria</a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <div class="card border-danger">
            <div class="card-header bg-danger p-3">
                <h4 class="card-title text-white mb-0">Exclusao de categoria</h4>
            </div>
            <div class="card-body">
                <% if (mensagemBloqueio) { %>
                    <div class="alert alert-danger">
                        <b>Exclusao bloqueada.</b>
                        <div><%= mensagemBloqueio %></div>
                    </div>
                    <p class="mb-4">Para excluir esta categoria, primeiro edite ou remova os cursos vinculados a ela.</p>
                <% } else { %>
                    <div class="alert alert-warning">
                        <b>Esta acao excluira o registro de forma permanente.</b>
                    </div>
                    <p class="mb-4">Tem certeza que deseja excluir a categoria abaixo?</p>
                <% } %>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th>Nome</th>
                                <td><%= categoria.nome %></td>
                            </tr>
                            <tr>
                                <th>Descricao</th>
                                <td><%= categoria.descricao || '-' %></td>
                            </tr>
                            <tr>
                                <th>Cursos vinculados</th>
                                <td><%= totalCursos %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <% if (!mensagemBloqueio) { %>
                    <form action="/categorias/<%= categoria.id %>/excluir" method="post">
                        <button type="submit" class="btn btn-danger mr-2">Confirmar Exclusao</button>
                        <a href="/categorias" class="btn btn-secondary">Cancelar</a>
                    </form>
                <% } else { %>
                    <a href="/cursos" class="btn btn-primary mr-2">Ver Cursos</a>
                    <a href="/categorias" class="btn btn-secondary">Voltar</a>
                <% } %>
            </div>
        </div>
    </div>
</div>
