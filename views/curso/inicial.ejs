<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
            <p class="mb-0">&raquo; Consulte todos os cursos do sistema</p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Cursos</a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Cursos cadastrados</h4>
                <a href="/cursos/criar" class="btn btn-primary mb-2">Adicionar Novo Curso</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-responsive-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Título</th>
                                <th>Preço</th>
                                <th>Categoria</th>
                                <th>Status</th>
                                <th>Criado em</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!cursos.length) { %>
                                <tr>
                                    <td colspan="7" class="text-center">Nenhum curso cadastrado.</td>
                                </tr>
                            <% } %>

                            <% for( let index = 0; index < cursos.length; index++ ) { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td><%= cursos[index].titulo %></td>
                                    <td><%= moneyFormat(cursos[index].preco) %></td>
                                    <td><%= cursos[index]?.categoria?.nome || '-' %></td>
                                    <td>
                                        <% if (cursos[index].status === 'publicado') { %>
                                            <span class="badge badge-primary">Publicado</span>
                                        <% } else if (cursos[index].status === 'arquivado') { %>
                                            <span class="badge badge-danger">Arquivado</span>
                                        <% } else { %>
                                            <span class="badge badge-warning">Rascunho</span>
                                        <% } %>
                                    </td>
                                    <td><%= dateFormat(cursos[index].criadoEm) %></td>
                                    <td>
                                        <a href="/cursos/<%= cursos[index].id %>" class="text-info mr-1">
                                            <i class="fa fa-eye fa-lg"></i>
                                        </a>
                                        <a href="/cursos/<%= cursos[index].id %>/editar" class="text-warning mr-1">
                                            <i class="fa fa-pencil fa-lg"></i>
                                        </a>
                                        <a href="/cursos/<%= cursos[index].id %>/excluir" class="text-danger">
                                            <i class="fa fa-trash fa-lg"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
