<% const canManageCategorias = Boolean(locals.canManageCategorias) %>
<% const canManageCursos = Boolean(locals.canManageCursos) %>
<% const canManageUsuarios = Boolean(locals.canManageUsuarios) %>

<div class="quixnav">
    <div class="quixnav-scroll">
        <ul class="metismenu" id="menu">
            <li class="nav-label first">Menu Principal</li>

            <li>
                <a href="/" aria-expanded="false">
                    <i class="icon icon-single-04"></i>
                    <span class="nav-text">Inicial</span>
                </a>
            </li>

            <% if (canManageCategorias) { %>
                <li>
                    <a href="/categorias" aria-expanded="false">
                        <i class="icon icon-tag"></i>
                        <span class="nav-text">Categorias</span>
                    </a>
                </li>
            <% } %>

            <% if (canManageCursos) { %>
                <li>
                    <a href="/cursos" aria-expanded="false">
                        <i class="icon icon-book-open-2"></i>
                        <span class="nav-text">Cursos</span>
                    </a>
                </li>
            <% } %>

            <% if (canManageUsuarios) { %>
                <li>
                    <a href="/usuarios" aria-expanded="false">
                        <i class="icon icon-users-mm"></i>
                        <span class="nav-text">Usuarios</span>
                    </a>
                </li>
            <% } %>

            <li>
                <a href="/sobre" aria-expanded="false">
                    <i class="icon icon-globe-2"></i>
                    <span class="nav-text">Sobre</span>
                </a>
            </li>
        </ul>
    </div>
</div>
