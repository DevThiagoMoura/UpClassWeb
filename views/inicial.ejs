<% const resumo = locals.resumo || {} %>
<% const authUser = locals.authUser || null %>
<% const canManageCategorias = Boolean(locals.canManageCategorias) %>
<% const canManageCursos = Boolean(locals.canManageCursos) %>
<% const canManageUsuarios = Boolean(locals.canManageUsuarios) %>
<% const canAccessPainel = canManageCategorias || canManageCursos || canManageUsuarios %>
<% const totalCategorias = resumo.totalCategorias || 0 %>
<% const categoriasAtivas = resumo.categoriasAtivas || 0 %>
<% const totalCursos = resumo.totalCursos || 0 %>
<% const cursosPublicados = resumo.cursosPublicados || 0 %>
<% const cursosRascunho = resumo.cursosRascunho || 0 %>
<% const totalUsuarios = resumo.totalUsuarios || 0 %>
<% const usuariosAtivos = resumo.usuariosAtivos || 0 %>
<% const usuariosAdministradores = resumo.usuariosAdministradores || 0 %>

<% if (!canAccessPainel) { %>
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">UpClass</h4>
                </div>
                <div class="card-body">
                    <% if (authUser) { %>
                        <div class="alert alert-info">
                            Seu acesso foi criado com perfil de aluno.
                        </div>
                        <p>
                            Esse perfil pode entrar no sistema, mas nao possui permissoes
                            para gerenciar cursos, categorias ou usuarios.
                        </p>
                        <p class="mb-4">
                            As telas administrativas ficam disponiveis apenas para perfis
                            de instrutor ou administrador, de acordo com a permissao de cada area.
                        </p>
                        <form action="/logout" method="post">
                            <button type="submit" class="btn btn-secondary">Sair</button>
                        </form>
                    <% } else { %>
                        <p>
                            Bem-vindo ao UpClass. Para acessar as funcionalidades do sistema,
                            entre com suas credenciais ou crie um cadastro.
                        </p>
                        <a href="/login" class="btn btn-primary mr-2">Entrar</a>
                        <a href="/cadastro" class="btn btn-outline-secondary">Cadastrar</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
<% } else { %>
    <div class="row">
        <% if (canManageCategorias) { %>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Categorias cadastradas</div>
                            <div class="stat-digit"><i class="fa fa-list"></i> <%= totalCategorias %></div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-primary w-100" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Categorias ativas</div>
                            <div class="stat-digit"><i class="fa fa-check-circle"></i> <%= categoriasAtivas %></div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-success w-100" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <% if (canManageCursos) { %>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Cursos cadastrados</div>
                            <div class="stat-digit"><i class="fa fa-book"></i> <%= totalCursos %></div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-warning w-100" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Cursos publicados</div>
                            <div class="stat-digit"><i class="fa fa-bullhorn"></i> <%= cursosPublicados %></div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-danger w-100" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <% if (canManageUsuarios) { %>
        <div class="row">
            <div class="col-lg-4 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Usuarios cadastrados</div>
                            <div class="stat-digit"><i class="fa fa-users"></i> <%= totalUsuarios %></div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-primary w-100" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Usuarios ativos</div>
                            <div class="stat-digit"><i class="fa fa-user"></i> <%= usuariosAtivos %></div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-success w-100" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-sm-6">
                <div class="card">
                    <div class="stat-widget-two card-body">
                        <div class="stat-content">
                            <div class="stat-text">Administradores</div>
                            <div class="stat-digit"><i class="fa fa-user-secret"></i> <%= usuariosAdministradores %></div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-warning w-100" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% } %>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">Painel do sistema</h4>
                </div>
                <div class="card-body">
                    <p>
                        O projeto cobre cadastro, listagem, visualizacao, edicao e remocao
                        de registros, alem de login com token assinado em cookie.
                    </p>
                    <% if (canManageCursos) { %>
                        <p>
                            Nos cursos, ha <strong><%= cursosPublicados %></strong> publicados
                            e <strong><%= cursosRascunho %></strong> em rascunho.
                        </p>
                    <% } %>
                    <% if (canManageCategorias) { %>
                        <a href="/categorias" class="btn btn-primary mr-2">Ir para Categorias</a>
                    <% } %>
                    <% if (canManageCursos) { %>
                        <a href="/cursos" class="btn btn-success mr-2">Ir para Cursos</a>
                    <% } %>
                    <% if (canManageUsuarios) { %>
                        <a href="/usuarios" class="btn btn-warning">Ir para Usuarios</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
<% } %>
