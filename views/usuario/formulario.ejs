<% const erros = validationErrors(locals.errors); %>
<% const usuario = locals.usuario || {} %>
<% const perfis = locals.perfis || ['aluno', 'instrutor', 'administrador'] %>
<% const ehEdicao = Boolean(usuario.id) %>

<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
            <p class="mb-0">&raquo; <%= locals.subtitulo || 'Preencha os dados do usuário' %></p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/usuarios">Consulta de Usuários</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Formulário</a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <% if (erros.all.length) { %>
                    <div class="alert alert-danger">
                        <% erros.all.forEach((mensagem) => { %>
                            <div><%= mensagem %></div>
                        <% }) %>
                    </div>
                <% } %>

                <form action="/usuarios/<%= usuario.id ? usuario.id + '/editar' : 'criar' %>" method="POST">
                    <div class="row">
                        <div class="col-md-6">
                            <label for="nome" class="form-label">Nome</label>
                            <input type="text" class="form-control <%= erros.has('nome') ? 'is-invalid' : '' %>"
                                id="nome" name="nome" placeholder="Informe o nome do usuário" value="<%= usuario.nome || '' %>">
                            <% if (erros.has('nome')) { %>
                                <div class="invalid-feedback d-block">
                                    <% erros.get('nome').forEach((mensagem) => { %>
                                        <div><%= mensagem %></div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                        <div class="col-md-6">
                            <label for="email" class="form-label">E-mail</label>
                            <input type="email" class="form-control <%= erros.has('email') ? 'is-invalid' : '' %>"
                                id="email" name="email" placeholder="Informe o e-mail" value="<%= usuario.email || '' %>">
                            <% if (erros.has('email')) { %>
                                <div class="invalid-feedback d-block">
                                    <% erros.get('email').forEach((mensagem) => { %>
                                        <div><%= mensagem %></div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-4">
                            <label for="cpf" class="form-label">CPF</label>
                            <input
                                type="text"
                                class="form-control <%= erros.has('cpf') ? 'is-invalid' : '' %>"
                                id="cpf"
                                name="cpf"
                                inputmode="numeric"
                                maxlength="14"
                                placeholder="000.000.000-00"
                                value="<%= usuario.cpf || '' %>"
                            >
                            <% if (erros.has('cpf')) { %>
                                <div class="invalid-feedback d-block">
                                    <% erros.get('cpf').forEach((mensagem) => { %>
                                        <div><%= mensagem %></div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                        <div class="col-md-4">
                            <label for="perfil" class="form-label">Perfil</label>
                            <select id="perfil" name="perfil" class="form-control <%= erros.has('perfil') ? 'is-invalid' : '' %>">
                                <% perfis.forEach((perfil) => { %>
                                    <option value="<%= perfil %>" <%= String(usuario.perfil || 'aluno') === perfil ? 'selected' : '' %>>
                                        <%= perfil === 'administrador' ? 'Administrador' : perfil === 'instrutor' ? 'Instrutor' : 'Aluno' %>
                                    </option>
                                <% }) %>
                            </select>
                            <% if (erros.has('perfil')) { %>
                                <div class="invalid-feedback d-block">
                                    <% erros.get('perfil').forEach((mensagem) => { %>
                                        <div><%= mensagem %></div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                        <div class="col-md-4">
                            <label for="ativo" class="form-label">Status</label>
                            <select id="ativo" name="ativo" class="form-control <%= erros.has('ativo') ? 'is-invalid' : '' %>">
                                <option value="true" <%= String(usuario.ativo ?? true) === 'true' ? 'selected' : '' %>>Ativo</option>
                                <option value="false" <%= String(usuario.ativo ?? true) === 'false' ? 'selected' : '' %>>Inativo</option>
                            </select>
                            <% if (erros.has('ativo')) { %>
                                <div class="invalid-feedback d-block">
                                    <% erros.get('ativo').forEach((mensagem) => { %>
                                        <div><%= mensagem %></div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label for="senha" class="form-label">Senha</label>
                            <input type="password" class="form-control <%= erros.has('senha') ? 'is-invalid' : '' %>"
                                id="senha" name="senha" placeholder="<%= ehEdicao ? 'Deixe em branco para manter a senha' : 'Crie uma senha' %>">
                            <% if (erros.has('senha')) { %>
                                <div class="invalid-feedback d-block">
                                    <% erros.get('senha').forEach((mensagem) => { %>
                                        <div><%= mensagem %></div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                        <div class="col-md-6">
                            <label for="confirmacaoSenha" class="form-label">Confirmação de senha</label>
                            <input type="password" class="form-control <%= erros.has('confirmacaoSenha') ? 'is-invalid' : '' %>"
                                id="confirmacaoSenha" name="confirmacaoSenha" placeholder="<%= ehEdicao ? 'Repita somente se alterar' : 'Repita a senha' %>">
                            <% if (erros.has('confirmacaoSenha')) { %>
                                <div class="invalid-feedback d-block">
                                    <% erros.get('confirmacaoSenha').forEach((mensagem) => { %>
                                        <div><%= mensagem %></div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Salvar</button>
                        <a href="/usuarios" class="btn btn-warning">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    (() => {
        const cpf = document.getElementById('cpf');

        if (!cpf) {
            return;
        }

        const formatCpf = (value) => {
            const digits = String(value || '').replace(/\D/g, '').slice(0, 11);
            const first = digits.slice(0, 3);
            const second = digits.slice(3, 6);
            const third = digits.slice(6, 9);
            const last = digits.slice(9, 11);

            let formatted = first;

            if (second) {
                formatted += `.${second}`;
            }

            if (third) {
                formatted += `.${third}`;
            }

            if (last) {
                formatted += `-${last}`;
            }

            return formatted;
        };

        const applyMask = () => {
            cpf.value = formatCpf(cpf.value);
        };

        cpf.addEventListener('input', applyMask);
        applyMask();
    })();
</script>
